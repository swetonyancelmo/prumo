# Frontend (Next.js) — copie para .env.local e preencha. NUNCA commitar .env.local.
# Variáveis NEXT_PUBLIC_* são expostas ao navegador (só use chaves públicas aqui).

# Projeto Supabase (mesmo projeto usado pelo backend).
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
# Chave pública/anon do Supabase (publishable key sb_publishable_... ou a anon key legada).
# É pública por design; a segurança real vem do RLS + validação de JWT no backend.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>

# URL base da API NestJS (inclui o prefixo /api).
NEXT_PUBLIC_API_URL=http://localhost:3000/api
