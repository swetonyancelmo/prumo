# ==========================================================================
# Ordenai — variáveis de ambiente (EXEMPLO). Copie para .env e preencha.
# NUNCA commite o .env real.
# ==========================================================================

# --- App ---
PORT=3000
NODE_ENV=development

# --- Postgres ---
# DATABASE_URL: usada pelo Prisma Client em runtime
# DIRECT_URL:   usada pelo `prisma migrate` (precisa de conexão direta, sem pooler)
#
# DEV (padrão): Postgres local em Docker — `docker compose up -d` na raiz do repo.
# Não há pooler local, então as duas URLs apontam para a mesma porta.
# Credenciais/porta vêm dos defaults do docker-compose.yml da raiz.
DATABASE_URL="postgresql://ordenai:ordenai_dev@localhost:5432/ordenai?schema=public"
DIRECT_URL="postgresql://ordenai:ordenai_dev@localhost:5432/ordenai?schema=public"

# PRODUÇÃO / Supabase: pegue em Dashboard > Project Settings > Database > Connection string.
# Lá o runtime usa o pooler (PgBouncer, 6543) e o migrate usa a conexão direta (5432):
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth (validação de JWT via JWKS / ES256) ---
# ATENÇÃO: o BANCO migrou para Docker local, mas a AUTENTICAÇÃO continua no Supabase.
# O backend ainda precisa de um projeto Supabase acessível para validar os JWTs, e o
# frontend ainda faz login por lá. Os UUIDs em `users.id` são os auth uid do Supabase.
# Project Settings > API. O backend valida o token buscando a chave pública em
# ${SUPABASE_URL}/auth/v1/.well-known/jwks.json e resolvendo pelo `kid` do token.
# Não há segredo compartilhado (chave assimétrica ECC P-256).
SUPABASE_URL="https://<ref>.supabase.co"
# Audience padrão dos tokens do Supabase
SUPABASE_JWT_AUDIENCE="authenticated"
